{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev --port 3003",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/kpis/route.ts":              { "maxDuration": 30 },
    "src/app/api/cron/refresh-kpis/route.ts": { "maxDuration": 130 }
  },
  "crons": [
    {
      "path": "/api/cron/refresh-kpis",
      "schedule": "0 7 * * *"
    }
  ]
}
